<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/rate-limited-allow-list-admin-frontend-tests.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%date{ISO8601} level=[%level] logger=[%logger] thread=[%thread] message=[%message] %replace(exception=[%xException]){'^exception=\[\]$',''}%n</pattern>
        </encoder>
    </appender>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%date{ISO8601} level=[%highlight(%level)] logger=[%logger] thread=[%thread] rid=[%X{X-Request-ID}] user=[%X{Authorization}] message=[%message] %replace(exception=[%xException]){'^exception=\[\]$',''}%n</pattern>
        </encoder>
    </appender>

    <logger name="com" level="OFF"/>
    <logger name="uk" level="OFF"/>
    <logger name="play" level="OFF"/>
    <logger name="application" level="OFF"/>
    <logger name="connector" level="OFF" />

    <logger name="WireMock" level="WARN" additivity="false">
        <!-- Enable logging of WireMock warn and error to stdout as these provide feedback for test execution on failure -->
        <appender-ref ref="STDOUT"/>
    </logger>

    <root level="OFF">
        <appender-ref ref="FILE"/>

        <!-- This appender is not enabled by default. Uncomment to view logs in stdout -->
        <!-- <appender-ref ref="STDOUT"/> -->
    </root>
</configuration>
